<nav class="sticky top-0 z-50 bg-[#F9F7F2]/80 dark:bg-[#050505]/80 backdrop-blur-md border-b border-black/5 dark:border-white/5 transition-colors duration-300">
  <div class="max-w-7xl mx-auto px-6 h-24 flex justify-between items-center">
    
    <a href="/" class="group flex flex-col">
      <span class="text-2xl font-bold tracking-tighter uppercase dark:text-white transition-colors">
        The Misings
      </span>
      <span class="text-[10px] uppercase tracking-[0.3em] text-gray-500 dark:text-gray-400 group-hover:text-[--mising-red] transition-colors">
        River People of Northeast India
      </span>
    </a>

    <div class="hidden md:flex items-center gap-10 text-[11px] font-bold uppercase tracking-[0.2em] dark:text-gray-300">
      <a href="/identity" class="hover:text-[--mising-red] transition-colors">Identity</a>
      <a href="/lifestyle" class="hover:text-[--mising-red] transition-colors">Lifestyle</a>
      <a href="/artistry" class="hover:text-[--mising-red] transition-colors">Artistry</a>
      <a href="/traditions" class="hover:text-[--mising-red] transition-colors">Traditions</a>
      
      <button id="themeToggle" class="theme-toggle ml-4 p-2 rounded-full hover:bg-black/5 dark:hover:bg-white/10 transition-all cursor-pointer" aria-label="Toggle Theme">
        <svg class="sun hidden dark:block w-4 h-4 text-yellow-500" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"></path></svg>
        <svg class="moon block dark:hidden w-4 h-4 text-gray-700" fill="currentColor" viewBox="0 0 20 20"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path></svg>
      </button>
    </div>

    <div class="md:hidden flex items-center gap-4">
      <button id="mobileThemeToggle" class="theme-toggle p-2 rounded-full dark:text-white">
          <div class="w-4 h-4 rounded-full border-2 border-current"></div>
      </button>
      <button id="menuBtn" class="dark:text-white uppercase text-[10px] font-bold tracking-widest border border-black/10 dark:border-white/10 px-3 py-1">Menu</button>
    </div>
  </div>

  <div id="mobileMenu" class="hidden flex-col bg-[#F9F7F2] dark:bg-[#050505] border-b border-black/5 px-6 py-8 gap-6 text-[12px] font-bold uppercase tracking-widest transition-all">
    <a href="/identity">Identity</a>
    <a href="/lifestyle">Lifestyle</a>
    <a href="/artistry">Artistry</a>
    <a href="/traditions">Traditions</a>
  </div>
</nav>

<script>
  function initNav() {
    const themeToggles = document.querySelectorAll(".theme-toggle");
    const menuBtn = document.getElementById("menuBtn");
    const mobileMenu = document.getElementById("mobileMenu");
    const mobileLinks = mobileMenu?.querySelectorAll("a");

    themeToggles.forEach(btn => {
      btn.addEventListener("click", () => {
        const element = document.documentElement;
        element.classList.toggle("dark");
        const isDark = element.classList.contains("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
      });
    });

    const closeMenu = () => {
      if (mobileMenu && !mobileMenu.classList.contains("hidden")) {
        mobileMenu.classList.add("hidden");
        mobileMenu.classList.remove("flex");
      }
    };

    menuBtn?.addEventListener("click", (e) => {
      e.stopPropagation();
      mobileMenu?.classList.toggle("hidden");
      mobileMenu?.classList.toggle("flex");
    });

    mobileLinks?.forEach(link => {
      link.addEventListener("click", closeMenu);
    });

    window.addEventListener("scroll", () => {
      if (window.scrollY > 10) {
        closeMenu();
      }
    }, { passive: true });

    document.addEventListener("click", (e) => {
      if (!mobileMenu?.contains(e.target as Node) && !menuBtn?.contains(e.target as Node)) {
        closeMenu();
      }
    });
  }

  initNav();

  document.addEventListener("astro:after-swap", initNav);
</script>