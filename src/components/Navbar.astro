---
const navItems = [
  { name: 'Heritage', href: '/heritage' },
  { name: 'Culture', href: '/culture' },
  { name: 'River Life', href: '/river-life' },
  { name: 'Resources', href: '/resources' },
  { name: 'Genealogy', href: '/genealogy' }
];
---

<nav class="bg-white border-b border-slate-200 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-20">
      
      <div class="flex items-center">
        <a href="/" class="group">
          <h1 class="text-2xl font-serif font-bold text-blue-900 group-hover:text-red-600 transition-colors leading-none">THE MISINGS</h1>
          <p class="text-[10px] tracking-[0.15em] uppercase font-semibold text-slate-500 mt-1">River People of NorthEast India</p>
        </a>
      </div>

      <div class="hidden md:flex items-center space-x-6">
        {navItems.map(item => (
          <a href={item.href} class="text-sm font-medium text-slate-700 hover:text-red-600 transition-colors">
            {item.name}
          </a>
        ))}
        
        <div id="google_translate_element" class="scale-90 px-2 py-1 bg-slate-50 rounded border border-slate-200"></div>
      </div>

      <div class="md:hidden flex items-center">
        <button id="menu-toggle" class="p-2 text-slate-600 focus:outline-none">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path></svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden bg-slate-50 border-t border-slate-200 px-4 py-4 space-y-3">
    {navItems.map(item => (
      <a href={item.href} class="block text-base font-medium text-slate-700 hover:text-red-600">{item.name}</a>
    ))}
  </div>
</nav>

<script>
  const btn = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;500;600&display=swap');
  h1 { font-family: 'Playfair Display', serif; }
  body { font-family: 'Inter', sans-serif; }
</style>