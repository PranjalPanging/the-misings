---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Genealogy Directory | Mising Heritage">
  <section class="py-16 bg-slate-50 min-h-screen">
    <div class="max-w-6xl mx-auto px-6">
      
      <div class="text-center mb-16">
        <h1 class="text-5xl font-serif font-bold text-blue-900 mb-4 tracking-tight">
          Mising Genealogy
        </h1>
        <p class="text-slate-600 max-w-2xl mx-auto text-lg leading-relaxed">
          Preserving the ancestral echoes of the Tani people. Select a lineage below to explore the branching history of our clans.
        </p>
        <div class="h-1 w-20 bg-blue-600 mx-auto mt-6 rounded-full"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        
        <!-- Doley Clan -->
        <a href="/genealogy/doley" class="group bg-white p-8 rounded-2xl shadow-sm border border-slate-200 hover:border-blue-600 hover:shadow-xl transition-all duration-300 flex flex-col justify-between">
          <div>
            <h2 class="text-2xl font-serif font-bold text-blue-900 group-hover:text-blue-600 transition-colors">Doley Clan</h2>
            <p class="text-slate-500 mt-3 text-sm leading-relaxed">Follow the patrilineal descent specifically through the Doley and Dolin branches.</p>
          </div>
          <span class="inline-block mt-6 text-blue-700 font-bold flex items-center gap-2 group-hover:translate-x-2 transition-transform">
            View Tree 
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
          </span>
        </a>


        <!-- Borang, Pérme & Pértin  -->
        <a href="/genealogy/borang-perme-pertin" class="group bg-white p-8 rounded-2xl shadow-sm border border-slate-200 hover:border-blue-600 hover:shadow-xl transition-all duration-300 flex flex-col justify-between">
          <div>
            <h2 class="text-2xl font-serif font-bold text-blue-900 group-hover:text-blue-600 transition-colors leading-tight">Borang, Pérme & Pértin</h2>
            <p class="text-slate-500 mt-3 text-sm leading-relaxed">Tracing the complex descent through Tingling, Tinrang, and the Ratan clan.</p>
          </div>
          <span class="inline-block mt-6 text-blue-700 font-bold flex items-center gap-2 group-hover:translate-x-2 transition-transform">
            View Tree 
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
          </span>
        </a>

        <!-- Longgíng -->
        <a href="/genealogy/longging" class="group bg-white p-8 rounded-2xl shadow-sm border border-slate-200 hover:border-blue-600 hover:shadow-xl transition-all duration-300 flex flex-col justify-between">
          <div>
            <h2 class="text-2xl font-serif font-bold text-blue-900 group-hover:text-blue-600 transition-colors">Longgíng Clan</h2>
            <p class="text-slate-500 mt-3 text-sm leading-relaxed">Explore the major ancestral branches including Gípang, Gíno, and Gíla.</p>
          </div>
          <span class="inline-block mt-6 text-blue-700 font-bold flex items-center gap-2 group-hover:translate-x-2 transition-transform">
            View Tree 
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
          </span>
        </a>

        

      </div>

      <div class="mt-12 bg-slate-100 p-8 rounded-2xl border border-dashed border-slate-300 text-center">
        <p class="text-slate-500 font-medium italic">More ancestral lineages are currently being documented...</p>
      </div>

    </div>
  </section>
</MainLayout>