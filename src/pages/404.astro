---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="404 - Page Not Found">
  <section class="flex items-center justify-center min-h-[60vh] px-6 py-24 bg-white">
    <div class="max-w-md w-full text-center">
      <div class="mb-6">
        <h1 class="text-9xl font-black text-slate-100 select-none">404</h1>
        <p class="text-2xl font-serif font-bold text-blue-900 -mt-12 relative">
          Page Not Found
        </p>
      </div>

      <div class="h-1 w-16 bg-red-600 mx-auto mb-6"></div>

      <p class="text-slate-600 mb-10 leading-relaxed">
        The resource you are looking for might have been removed, had its name changed, or is temporarily unavailable.
      </p>

      <div class="space-y-3">
        <a 
          href="/" 
          class="block w-full bg-blue-900 hover:bg-blue-800 text-white font-semibold py-3 px-6 rounded-lg transition-colors shadow-sm"
        >
          Go to Homepage
        </a>
        
        <div class="grid grid-cols-2 gap-3">
          <a 
            href="/heritage" 
            class="text-sm font-medium text-slate-700 bg-slate-100 hover:bg-slate-200 py-3 px-4 rounded-lg transition-colors"
          >
            History
          </a>
          <a 
            href="/culture" 
            class="text-sm font-medium text-slate-700 bg-slate-100 hover:bg-slate-200 py-3 px-4 rounded-lg transition-colors"
          >
            Culture
          </a>
        </div>
      </div>

      <p class="mt-12 text-sm text-slate-400">
        Lost? Try checking the URL for typos.
      </p>
    </div>
  </section>
</MainLayout>